{
  "name": "@inkdropapp/ipm-cli",
  "version": "1.0.6",
  "description": "The CLI tool for managing Inkdrop plugins",
  "keywords": [
    "Inkdrop"
  ],
  "homepage": "https://github.com/inkdropapp/ipm-cli#readme",
  "bugs": {
    "url": "https://github.com/inkdropapp/ipm-cli/issues"
  },
  "license": "MIT",
  "author": "Takuya Matsuyama <t@inkdrop.app>",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/inkdropapp/ipm-cli.git"
  },
  "bin": {
    "ipm": "./bin/cli.js"
  },
  "files": [
    "bin",
    "lib"
  ],
  "type": "module",
  "main": "lib/index.mjs",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "node --env-file=.env ./bin/cli.js",
    "format": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inkdropapp/ipm": "^1.0.7",
    "@inkdropapp/logger": "^4.0.0",
    "@napi-rs/keyring": "^1.3.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
