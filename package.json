{
  "name": "@inkdropapp/ipm-cli",
  "version": "1.2.2",
  "description": "The CLI tool for managing Inkdrop plugins",
  "keywords": [
    "Inkdrop"
  ],
  "homepage": "https://github.com/inkdropapp/ipm-cli#readme",
  "bugs": {
    "url": "https://github.com/inkdropapp/ipm-cli/issues"
  },
  "license": "MIT",
  "author": "Takuya Matsuyama <t@inkdrop.app>",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/inkdropapp/ipm-cli.git"
  },
  "bin": {
    "ipm": "./bin/cli.js"
  },
  "files": [
    "bin",
    "lib",
    "templates"
  ],
  "type": "module",
  "main": "lib/index.mjs",
  "scripts": {
    "build": "tsdown",
    "dev": "node --env-file=.env ./bin/cli.js",
    "watch": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inkdropapp/ipm": "^1.1.0",
    "@inkdropapp/logger": "^4.0.0",
    "@napi-rs/keyring": "^1.3.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "4.1.10",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
